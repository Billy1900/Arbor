FROM rust:1.78-slim AS builder
WORKDIR /build
RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
COPY migrations/ migrations/
RUN cargo build --release -p arbor-runner-agent

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y \
  ca-certificates libssl3 \
  iproute2 iptables nftables \
  && rm -rf /var/lib/apt/lists/*
COPY --from=builder /build/target/release/arbor-runner-agent /usr/local/bin/arbor-runner-agent
ENTRYPOINT ["/usr/local/bin/arbor-runner-agent"]

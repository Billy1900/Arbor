# Arbor — environment configuration
# Copy to .env and fill in real values before deploying.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
ARBOR__DATABASE_URL=postgresql://arbor:arbor_dev_only@postgres:5432/arbor

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ARBOR__ATTACH_TOKEN_SECRET=change-me-before-production

# ── API server ────────────────────────────────────────────────────────────────
ARBOR__BIND=0.0.0.0:8080
ARBOR__API_BASE_URL=http://localhost:8080

# ── Snapshot storage ──────────────────────────────────────────────────────────
# Local filesystem (dev):
ARBOR__OBJECT_STORE_URL=local:///var/lib/arbor/snapshots/store
ARBOR__OBJECT_STORE_PREFIX=checkpoints

# S3/MinIO (production) — enable with --features s3:
# AWS_ACCESS_KEY_ID=minio
# AWS_SECRET_ACCESS_KEY=minio123
# AWS_REGION=us-east-1
# ARBOR__OBJECT_STORE_URL=http://minio:9000
# ARBOR__OBJECT_STORE_PREFIX=arbor-checkpoints

# ── Firecracker ───────────────────────────────────────────────────────────────
ARBOR__KERNEL_PATH=/var/lib/arbor/firecracker/vmlinux
ARBOR__DEFAULT_RUNNER_CLASS=fc-x86_64-v1

# ── Runner agent ─────────────────────────────────────────────────────────────
ARBOR_RUNNER__BIND=0.0.0.0:9090
ARBOR_RUNNER__FC_BINARY=/var/lib/arbor/firecracker/bin/firecracker
ARBOR_RUNNER__JAILER_BINARY=/var/lib/arbor/firecracker/bin/jailer
ARBOR_RUNNER__KERNEL_PATH=/var/lib/arbor/firecracker/vmlinux
ARBOR_RUNNER__WORKSPACES_DIR=/var/lib/arbor/workspaces
ARBOR_RUNNER__BASE_IMAGES_DIR=/var/lib/arbor/images

# ── Egress proxy ──────────────────────────────────────────────────────────────
ARBOR_PROXY_BIND=0.0.0.0:3128

# ── Provider secrets (brokered — never enter VM) ─────────────────────────────
# Naming: ARBOR_SECRET_<VAULT_REF sanitized to uppercase underscores>
# Example: vault://org/prod/openai-api-key → ARBOR_SECRET_ORG_PROD_OPENAI_API_KEY
ARBOR_SECRET_ORG_PROD_OPENAI_API_KEY=sk-...
ARBOR_SECRET_ORG_PROD_ANTHROPIC_API_KEY=sk-ant-...
ARBOR_SECRET_ORG_PROD_GITHUB_TOKEN=ghp_...

# ── MinIO credentials (dev object store) ─────────────────────────────────────
MINIO_ROOT_USER=arbor
MINIO_ROOT_PASSWORD=arbor_dev_only

# ── PostgreSQL credentials ────────────────────────────────────────────────────
POSTGRES_PASSWORD=arbor_dev_only

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=arbor_api=info,arbor_controller=info,arbor_runner_agent=debug,tower_http=info
